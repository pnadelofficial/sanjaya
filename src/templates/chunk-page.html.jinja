{% extends "base.html.jinja" %}

{% block content %}
<a href="{{ depth_prefix }}index.html">← Home</a>
<h1>{{ title }}</h1>

{% set known_roles = ['gloss', 'translation', 'base_text'] %}

{% for sentence in sentences %}
<div class="sentence-block">

  {% if 'gloss' in sentence %}
  <p class="sentence">
    {% for token in sentence.gloss %}
      <span class="glossed-token"
        id="{{ token.id }}"
        data-gloss="{{ token.annotation.gloss }}"
        data-form="{{ token.text }}"
        data-pagefind-meta="form[data-form], gloss[data-gloss]"
        data-pagefind-index-attrs="data-gloss,data-form">
        {{ token.text }}
      </span>
    {% endfor %}
  </p>
  {% elif sentence.gloss_failed %}
  <p class="sentence">{{ sentence.base_text }}</p>
  <p class="annotation-error">Gloss annotations unavailable for this passage.</p>
  {% endif %}

  {% if 'translation' in sentence %}
  <p><i>Translation</i>: {{ sentence.translation.annotation.translation }}</p>
  <details class="note">
    <summary>See notes</summary>
    <span>{{ sentence.translation.annotation.notes }}</span>
  </details>
  {% elif sentence.translation_failed %}
  <p class="annotation-error">Translation unavailable for this passage.</p>
  {% endif %}

  {% for key, value in sentence.items() %}
    {% if key not in known_roles and not key.endswith('_failed') %}
    <details class="note">
      <summary>{{ key }}</summary>
      <pre class="annotation-raw">{{ value | tojson(indent=2) }}</pre>
    </details>
    {% endif %}
  {% endfor %}

</div>
<br>
{% endfor %}

{% endblock %}
