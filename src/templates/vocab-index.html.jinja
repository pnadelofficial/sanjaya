{% extends "base.html.jinja" %}

{% block content %}
<p class="reference"><a href="{{ depth_prefix }}index.html">← Home</a></p>
<h1>Vocabulary</h1>
<h2>{{ work }}</h2>
<p class="reference">{{ forms | length }} unique forms</p>

<ul class="vocab-list">
  {% for form in forms %}
  <li><a href="{{ form }}.html">{{ form }}</a></li>
  {% endfor %}
</ul>
{% endblock %}
